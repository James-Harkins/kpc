</style>

<div class="next-trip-cost">
    <% flash.each do |name, msg| %>
        <div class="alert" role="alert">
            <%= content_tag :div, msg, class: name %>
        </div>
    <% end %>
    <h1>Finances</h1>
    <table class="finances-summary">
      <tbody>
        <tr class="summary-section-header">
          <td colspan="2">Financial Summary</td>
        </tr>
        <tr>
          <td>Projected Revenue</td>
          <td>$<%= number_with_delimiter(@next_trip.total_projected_revenue) %></td>
        </tr>
        <tr>
          <td>Total Expenses</td>
          <td>$<%= number_with_delimiter(@next_trip.total_expenses) %></td>
        </tr>
        <tr class="balance-row">
          <td>Balance</td>
          <td>$<%= number_with_delimiter(@next_trip.balance) %></td>
        </tr>
        <tr class="summary-section-header">
          <td colspan="2">Payment Status</td>
        </tr>
        <tr>
          <td>Collected</td>
          <td>$<%= number_with_delimiter(@next_trip.total_collected_revenue) %></td>
        </tr>
        <tr>
          <td>Uncollected</td>
          <td>$<%= number_with_delimiter(@next_trip.total_uncollected_revenue) %></td>
        </tr>
        <tr>
          <td>Man-Nights</td>
          <td><%= @next_trip.total_man_nights %></td>
        </tr>
      </tbody>
    </table>
    <%= button_to "View Expenses", expenses_path, method: :get, class: 'btn btn-outline-primary-green', params: { trip_id: @next_trip.id } %>
    <hr class="line">
    <% if current_user.email == ENV["SITE_ADMIN_EMAIL"] %>
      <%= form_with url: trip_financial_summaries_path, method: :post, local: true do |form| %>
        <%= form.hidden_field :trip_id, value: @next_trip.id %>
        <%= form.submit "Finalize Trip Finances", class: 'btn btn-outline-primary' %>
      <% end %>
    <% end %>
    <% if @summary %>
      <hr class="line-thin">
      <h2>Trip Financial Summary</h2>
      <table class="finances-summary">
        <tbody>
          <tr>
            <td>Total Revenue</td>
            <td>$<%= number_with_delimiter(@summary.total_revenue) %></td>
          </tr>
          <tr>
            <td>Total Expenses</td>
            <td>$<%= number_with_delimiter(@summary.total_expenses) %></td>
          </tr>
          <tr class="balance-row">
            <td>Total Deficit</td>
            <td>$<%= number_with_delimiter(@summary.total_deficit) %></td>
          </tr>
          <tr class="summary-section-header">
            <td colspan="2">Committee</td>
          </tr>
          <tr>
            <td>Members</td>
            <td><%= @summary.committee_count %></td>
          </tr>
          <tr>
            <td>Fair Share (per member)</td>
            <td>$<%= number_with_delimiter(@summary.fair_share) %></td>
          </tr>
        </tbody>
      </table>
      <h2>Committee Cost Sharing</h2>
      <% if @breakdown.any? %>
        <% @breakdown.each do |b| %>
          <div class="golfer-card">
            <h4>
              <%= b[:golfer].nickname == "Walnuts" ? b[:golfer].first_name : b[:golfer].first_name.capitalize %> "<%= b[:golfer].nickname.titleize %>" <%= b[:golfer].last_name.capitalize %>
              <% if b[:is_treasurer] %>
                <span style="font-size: 0.65em; font-weight: normal; color: #555; margin-left: 8px;">Treasurer</span>
              <% end %>
            </h4>
            <% if b[:is_treasurer] %>
              <h5>Expenses Paid: <strong>$<%= number_with_delimiter(b[:expenses_paid]) %></strong></h5>
              <h5>Revenue Collected: <strong>$<%= number_with_delimiter(b[:revenue_collected]) %></strong></h5>
              <h5>Net Out of Pocket: <strong>$<%= number_with_delimiter(b[:paid]) %></strong></h5>
            <% else %>
              <h5>Paid: <strong>$<%= number_with_delimiter(b[:paid]) %></strong></h5>
            <% end %>
            <h5>Fair Share: <strong>$<%= number_with_delimiter(b[:fair_share].round) %></strong></h5>
            <% if b[:balance].round >= 0 %>
              <h5 style="color: green; font-weight: bold;">Owed back: $<%= number_with_delimiter(b[:balance].round) %></h5>
            <% else %>
              <h5 style="color: #c0392b; font-weight: bold;">Owes: $<%= number_with_delimiter(b[:balance].abs.round) %></h5>
            <% end %>
          </div>
        <% end %>
        <% if @settlements.any? %>
          <h3>Settlements</h3>
          <% @settlements.each do |s| %>
            <div class="golfer-card">
              <h5>
                <%= s[:payer].nickname.titleize %> pays <%= s[:payee].nickname.titleize %>
                &mdash; <strong>$<%= number_with_delimiter(s[:amount]) %></strong>
              </h5>
            </div>
          <% end %>
        <% else %>
          <h3 style="color: green; font-weight: bold;">All even &mdash; no settlements needed!</h3>
        <% end %>
      <% else %>
        <h3 style="color: #888; font-style: italic;">No expenses assigned to committee members yet.</h3>
      <% end %>
      <% if current_user.email == ENV["SITE_ADMIN_EMAIL"] && !@next_trip.completed? %>
        <hr class="line-thin">
        <%= form_with url: complete_trip_path(@next_trip.id), method: :patch, local: true do |form| %>
          <%= form.submit "Complete Trip", class: 'btn btn-outline-primary' %>
        <% end %>
      <% end %>
    <% end %>
    <hr class="line">
    <% trip_nights = @next_trip.nights.order(:date).to_a %>
    <% trip_rounds_by_date = @next_trip.rounds.order(:date).index_by(&:date) %>
    <% paid_trips = @next_trip.paid_golfer_trips %>
    <% if paid_trips.any? %>
      <h3><u>Paid:</u></h3>
    <% else %>
      <h3 style="color: #888; font-style: italic;">No one is fully paid yet.</h3>
    <% end %>
    <% paid_trips.each do |golfer_trip| %>
        <% golfer = golfer_trip.golfer %>
        <% net_paid = golfer_trip.payments.sum(:amount) %>
        <% golfer_night_ids = golfer.nights.where(trip_id: @next_trip.id).pluck(:id).to_set %>
        <% golfer_round_ids = golfer.rounds.where(trip_id: @next_trip.id).pluck(:id).to_set %>
        <div class="golfer-card">
          <h4><%= golfer.nickname == "Walnuts" ? golfer.first_name.strip : golfer.first_name.capitalize.strip %> "<%= golfer.nickname.titleize.strip %>" <%= golfer.last_name.capitalize.strip %> &mdash; $<%= number_with_delimiter(golfer_trip.cost) %></h4>
          <div class="trip-calendar">
            <div class="cal-dates">
              <% trip_nights.each do |night| %>
                <div class="cal-date"><%= night.date.strftime('%a') %><br><%= night.date.day %></div>
              <% end %>
            </div>
            <div class="cal-bar">
              <% trip_nights.each do |night| %>
                <div class="cal-segment <%= 'night-active' if golfer_night_ids.include?(night.id) %>"></div>
              <% end %>
            </div>
            <div class="cal-bar">
              <% trip_nights.each do |night| %>
                <% round = trip_rounds_by_date[night.date] %>
                <div class="cal-segment <%= 'round-active' if round && golfer_round_ids.include?(round.id) %>"></div>
              <% end %>
            </div>
            <div class="cal-legend">
              <span><span class="cal-legend-dot" style="background:#4a90d9"></span>Nights</span>
              <span><span class="cal-legend-dot" style="background:#e87f3a"></span>Rounds</span>
            </div>
          </div>
          <% if golfer.registered_full_trip(@next_trip.id) %>
            <h5>Whole Enchilada!</h5>
          <% else %>
            <h5>Nights: <span style="font-weight:normal"><%= golfer.trip_night_calendar(@next_trip.id).join(', ') %></span></h5>
            <h5>Rounds: <span style="font-weight:normal"><%= golfer.trip_round_calendar(@next_trip.id).join(', ') %></span></h5>
          <% end %>
          <% if current_user.email == ENV["SITE_ADMIN_EMAIL"] %>
            <h5>Net Paid: $<%= number_with_delimiter(net_paid) %></h5>
            <% if net_paid > golfer_trip.cost %>
              <h5 class="overpaid-warning">Overpaid by $<%= number_with_delimiter(net_paid - golfer_trip.cost) %> — return needed</h5>
            <% end %>
            <%= button_to "Edit Trip", edit_golfer_trip_path(golfer_trip), method: :get, class: 'btn btn-outline-primary' %>
            <%= form_with url: "/returns", method: :post, local: true do |form| %>
              <h5><%= form.label :amount, 'Process Return' %></h5>
              <%= form.number_field :amount %>
              <%= form.button "Return", name: :golfer_trip_id, value: golfer_trip.id, class: 'btn-outline-danger' %>
            <% end %>
          <% end %>
        </div>
    <% end %>
    <hr class="line">
    <% unpaid_trips = @next_trip.unpaid_golfer_trips %>
    <% if unpaid_trips.any? %>
      <h3><u>Unpaid:</u></h3>
    <% else %>
      <h3 style="color: green; font-weight: bold;">Everyone is fully paid!</h3>
    <% end %>
    <% unpaid_trips.each do |golfer_trip| %>
        <% golfer = golfer_trip.golfer %>
        <% net_paid = golfer_trip.payments.sum(:amount) %>
        <% golfer_night_ids = golfer.nights.where(trip_id: @next_trip.id).pluck(:id).to_set %>
        <% golfer_round_ids = golfer.rounds.where(trip_id: @next_trip.id).pluck(:id).to_set %>
        <div class="golfer-card">
          <h4><%= golfer.nickname == "Walnuts" ? golfer.first_name.strip : golfer.first_name.capitalize.strip %> "<%= golfer.nickname.titleize.strip %>" <%= golfer.last_name.capitalize.strip %> &mdash; $<%= number_with_delimiter(golfer_trip.cost) %></h4>
          <div class="trip-calendar">
            <div class="cal-dates">
              <% trip_nights.each do |night| %>
                <div class="cal-date"><%= night.date.strftime('%a') %><br><%= night.date.day %></div>
              <% end %>
            </div>
            <div class="cal-bar">
              <% trip_nights.each do |night| %>
                <div class="cal-segment <%= 'night-active' if golfer_night_ids.include?(night.id) %>"></div>
              <% end %>
            </div>
            <div class="cal-bar">
              <% trip_nights.each do |night| %>
                <% round = trip_rounds_by_date[night.date] %>
                <div class="cal-segment <%= 'round-active' if round && golfer_round_ids.include?(round.id) %>"></div>
              <% end %>
            </div>
            <div class="cal-legend">
              <span><span class="cal-legend-dot" style="background:#4a90d9"></span>Nights</span>
              <span><span class="cal-legend-dot" style="background:#e87f3a"></span>Rounds</span>
            </div>
          </div>
          <% if golfer.registered_full_trip(@next_trip.id) %>
            <h5>Whole Enchilada!</h5>
          <% else %>
            <h5>Nights: <span style="font-weight:normal"><%= golfer.trip_night_calendar(@next_trip.id).join(', ') %></span></h5>
            <h5>Rounds: <span style="font-weight:normal"><%= golfer.trip_round_calendar(@next_trip.id).join(', ') %></span></h5>
          <% end %>
          <% if current_user.email == ENV["SITE_ADMIN_EMAIL"] %>
            <h5>Net Paid: $<%= number_with_delimiter(net_paid) %></h5>
          <% end %>
          <h5>Outstanding Balance: $<%= number_with_delimiter(golfer_trip.balance) %></h5>
          <%= button_to "Mark as Paid", "/update_golfer_payment", method: :put, class: 'btn btn-outline-primary', params: { golfer_trip_id: golfer_trip.id, paid: true } %>
          <%= form_with url: "/payments", method: :post, local: true do |form| %>
            <h5><%= form.label :amount, 'Add a Payment' %></h5>
            <%= form.number_field :amount %>
            <%= form.button "Add Payment", name: :golfer_trip_id, value: golfer_trip.id %>
          <% end %>
          <% if current_user.email == ENV["SITE_ADMIN_EMAIL"] %>
            <%= button_to "Edit Trip", edit_golfer_trip_path(golfer_trip), method: :get, class: 'btn btn-outline-primary' %>
            <%= form_with url: "/returns", method: :post, local: true do |form| %>
              <h5><%= form.label :amount, 'Process Return' %></h5>
              <%= form.number_field :amount %>
              <%= form.button "Return", name: :golfer_trip_id, value: golfer_trip.id, class: 'btn-outline-danger' %>
            <% end %>
          <% end %>
        </div>
    <% end %>
    <hr class="line">

    <form action="/dashboard">
        <button id="dashboard_header" type="submit" class="btn btn-outline-primary">DASHBOARD</button>
    </form>
    <%= button_to "LOG OUT", "/logout", method: :delete, class: "btn btn-outline-primary", id: "dashboard_header" %>
</div>