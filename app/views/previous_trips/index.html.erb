<style>
body {
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    flex-flow: column;
    color: #fff;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
}

body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: url(<%= asset_path 'course_6.jpg' %>) center/cover no-repeat;
    z-index: -1;
}

.next-trip-cost {
    background-color: #fff;
    opacity: .8;
    padding: 30px 40px;
    margin: 20px auto;
    color: black;
    border-radius: 10px;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    text-align: left;
    max-width: 900px;
    width: 90%;
}

.next-trip-cost > h1 {
    font-size: 50px;
    text-align: center;
    margin: 0 0 4px;
}

.next-trip-cost > h3 {
    font-size: 24px;
    text-align: center;
    margin: 0 0 20px;
    color: #555;
    font-weight: normal;
}

.line {
    border-top: 5px solid black;
}

.finances-summary {
    width: 100%;
    border-collapse: collapse;
    font-size: 18px;
    margin: 12px 0 20px;
}

.finances-summary td {
    padding: 9px 14px;
    border-bottom: 1px solid #ddd;
}

.finances-summary td:last-child {
    text-align: right;
    font-weight: 600;
    white-space: nowrap;
}

.finances-summary .balance-row td {
    border-top: 2px solid #333;
    border-bottom: none;
    font-weight: 700;
    font-size: 20px;
}

.finances-summary .summary-section-header td {
    padding: 16px 14px 4px;
    border-bottom: none;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666;
}

.finances-summary .summary-section-header:first-child td {
    padding-top: 4px;
}

.no-summary {
    color: #888;
    font-style: italic;
    font-size: 17px;
    margin: 12px 0 20px;
}

.attendance-grid {
    width: 100%;
    margin: 12px 0 8px;
}

.attendance-row {
    display: flex;
    align-items: flex-start;
    margin-bottom: 5px;
}

.golfer-name-col {
    width: 90px;
    flex-shrink: 0;
    font-size: 14px;
    color: #444;
    padding-right: 10px;
    padding-top: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.attendance-bars {
    flex: 1;
    min-width: 0;
}

.cal-dates {
    display: flex;
    margin-bottom: 3px;
}

.cal-date {
    flex: 1;
    text-align: center;
    font-size: 13px;
    color: #555;
    line-height: 1.3;
    transition: color 0.12s ease;
}

.cal-date-highlighted {
    color: #111;
    font-weight: bold;
}

.attendance-grid:has(.attendance-row:not(.attendance-header-row):hover) .cal-date:not(.cal-date-highlighted) {
    opacity: 0.15;
}

.cal-bar {
    display: flex;
    height: 7px;
    border-radius: 4px;
    overflow: hidden;
    background-color: rgba(0, 0, 0, 0.08);
    margin-bottom: 2px;
}

.cal-segment {
    flex: 1;
    height: 100%;
    background-color: transparent;
}

.night-active {
    background-color: #4a90d9;
}

.round-active {
    background-color: #e87f3a;
}

.cal-legend {
    display: flex;
    gap: 14px;
    margin-top: 6px;
    font-size: 13px;
    color: #555;
}

.attendance-row {
    transition: opacity 0.12s ease;
    cursor: default;
}

.attendance-header-row {
    cursor: default;
}

.attendance-grid:has(.attendance-row:not(.attendance-header-row):hover) .attendance-row:not(:hover):not(.attendance-header-row) {
    opacity: 0.25;
}

.attendance-row:hover .golfer-name-col {
    font-weight: bold;
    color: #111;
}

.cal-legend-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 3px;
    vertical-align: middle;
}

.finalized-at {
    font-size: 13px;
    color: #888;
    margin: 0 0 8px;
    text-align: right;
}

.btn-outline-primary {
    margin: 1rem 0;
    background-color: white;
    opacity: .8;
    padding: 20px;
    font-size: 1em;
    color: black !important;
    outline: 0 none !important;
    box-shadow: none !important;
    border-color: black !important;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    border-radius: 10px;
    cursor: pointer;
}

.btn-outline-primary:hover {
    background-color: gray !important;
}

@media (max-width: 800px) {
    body { align-items: stretch; }
    .next-trip-cost { padding: 20px 18px; }
    .next-trip-cost > h1 { font-size: 36px; }
    .golfer-name-col { width: 70px; font-size: 12px; }
}
</style>

<% if @trips.any? %>
  <% @trips.each do |trip| %>
    <div class="next-trip-cost">
      <h1>KPC <%= trip.number %></h1>
      <h3><%= trip.location %> &mdash; <%= trip.year %></h3>

      <% summary = trip.trip_financial_summary %>
      <% if summary %>
        <p class="finalized-at">Finalized <%= summary.updated_at.strftime('%B %-d, %Y') %></p>
        <table class="finances-summary">
          <tbody>
            <tr>
              <td>Total Revenue</td>
              <td>$<%= number_with_delimiter(summary.total_revenue) %></td>
            </tr>
            <tr>
              <td>Total Expenses</td>
              <td>$<%= number_with_delimiter(summary.total_expenses) %></td>
            </tr>
            <tr class="balance-row">
              <td>Total Deficit</td>
              <td>$<%= number_with_delimiter(summary.total_deficit) %></td>
            </tr>
            <tr class="summary-section-header">
              <td colspan="2">Committee</td>
            </tr>
            <tr>
              <td>Members</td>
              <td><%= summary.committee_count %></td>
            </tr>
            <tr>
              <td>Fair Share (per member)</td>
              <td>$<%= number_with_delimiter(summary.fair_share) %></td>
            </tr>
          </tbody>
        </table>
      <% else %>
        <p class="no-summary">No financial summary recorded.</p>
      <% end %>

      <hr class="line">

      <% trip_nights = trip.nights.sort_by(&:date) %>
      <% if trip_nights.any? %>
        <% trip_rounds_by_date = trip.rounds.index_by(&:date) %>
        <% non_admin_golfers = trip.golfers.where(role: :default).order(:nickname) %>
        <% if non_admin_golfers.any? %>
          <div class="attendance-grid">
            <div class="attendance-row attendance-header-row">
              <div class="golfer-name-col"></div>
              <div class="attendance-bars">
                <div class="cal-dates">
                  <% trip_nights.each do |night| %>
                    <div class="cal-date"><%= night.date.strftime('%a') %><br><%= night.date.day %></div>
                  <% end %>
                </div>
              </div>
            </div>
            <% non_admin_golfers.each do |golfer| %>
              <% golfer_night_ids = golfer.nights.where(trip_id: trip.id).pluck(:id).to_set %>
              <% golfer_round_ids = golfer.rounds.where(trip_id: trip.id).pluck(:id).to_set %>
              <div class="attendance-row">
                <div class="golfer-name-col"><%= golfer.nickname.titleize %></div>
                <div class="attendance-bars">
                  <div class="cal-bar">
                    <% trip_nights.each do |night| %>
                      <div class="cal-segment <%= 'night-active' if golfer_night_ids.include?(night.id) %>"></div>
                    <% end %>
                  </div>
                  <div class="cal-bar">
                    <% trip_nights.each do |night| %>
                      <% round = trip_rounds_by_date[night.date] %>
                      <div class="cal-segment <%= 'round-active' if round && golfer_round_ids.include?(round.id) %>"></div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          <div class="cal-legend">
            <span><span class="cal-legend-dot" style="background:#4a90d9"></span>Nights</span>
            <span><span class="cal-legend-dot" style="background:#e87f3a"></span>Rounds</span>
          </div>
        <% else %>
          <p class="no-summary">No non-admin golfers registered for this trip.</p>
        <% end %>
      <% else %>
        <p class="no-summary">No calendar data available.</p>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="next-trip-cost">
    <h3 style="text-align: center; color: #888; font-style: italic;">No previous trips found.</h3>
  </div>
<% end %>

<div style="margin-bottom: 20px;">
  <form action="/dashboard">
    <button type="submit" class="btn btn-outline-primary">Dashboard</button>
  </form>
</div>

<script>
  document.querySelectorAll('.attendance-grid').forEach(function(grid) {
    var headerDates = grid.querySelectorAll('.cal-dates .cal-date');
    grid.querySelectorAll('.attendance-row:not(.attendance-header-row)').forEach(function(row) {
      row.addEventListener('mouseenter', function() {
        var activeIndices = new Set();
        row.querySelectorAll('.cal-bar').forEach(function(bar) {
          bar.querySelectorAll('.cal-segment').forEach(function(seg, idx) {
            if (seg.classList.contains('night-active') || seg.classList.contains('round-active')) {
              activeIndices.add(idx);
            }
          });
        });
        headerDates.forEach(function(dateEl, idx) {
          dateEl.classList.toggle('cal-date-highlighted', activeIndices.has(idx));
        });
      });
      row.addEventListener('mouseleave', function() {
        headerDates.forEach(function(dateEl) {
          dateEl.classList.remove('cal-date-highlighted');
        });
      });
    });
  });
</script>
