<style>
body {
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    flex-flow: column;
    color: #fff;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
}

body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: url(<%= asset_path 'course_1.jpg' %>) center/cover no-repeat;
    z-index: -1;
}

.next-trip-cost {
    background-color: #fff;
    opacity: .8;
    padding: 30px 40px;
    margin: 20px auto;
    color: black;
    border-radius: 10px;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    text-align: left;
    max-width: 700px;
    width: 90%;
}

.next-trip-cost > h1 {
    font-size: 60px;
    text-align: center;
}

.form-group {
    margin: 16px 0;
}

.form-group label {
    display: block;
    font-size: 1.1em;
    font-weight: bold;
    margin-bottom: 6px;
}

.form-group input,
.form-group textarea,
.form-group select {
    width: 100%;
    padding: 10px 14px;
    font-size: 1em;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 6px;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    box-sizing: border-box;
}

.btn-outline-primary {
    margin: 1rem 0;
    background-color: white;
    opacity: .8;
    padding: 20px;
    font-size: 1em;
    color: black !important;
    outline: 0 none !important;
    box-shadow: none !important;
    border-color: black !important;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    border-radius: 10px;
    cursor: pointer;
}

.btn-outline-primary:hover {
    background-color: gray !important;
}

@media (max-width: 800px) {
    body { align-items: stretch; }
}
</style>

<div class="next-trip-cost">
    <% flash.each do |name, msg| %>
        <div class="alert" role="alert">
            <%= content_tag :div, msg, class: name %>
        </div>
    <% end %>
    <h1>New Expense</h1>
    <%= form_with model: @expense, url: expenses_path(trip_id: @trip.id), local: true do |form| %>
        <div class="form-group">
            <%= form.label :golfer_id, "Assigned To" %>
            <%= form.collection_select :golfer_id, @admin_golfers, :id,
                ->(g) { "#{g.first_name.capitalize} \"#{g.nickname.titleize}\" #{g.last_name.capitalize}" },
                { prompt: "Select a committee member" } %>
        </div>
        <div class="form-group">
            <%= form.label :description, "Description" %>
            <%= form.text_field :description, placeholder: "e.g. Groceries" %>
        </div>
        <div class="form-group">
            <%= form.label :amount, "Amount ($)" %>
            <%= form.number_field :amount, placeholder: "e.g. 250" %>
        </div>
        <div class="form-group">
            <%= form.label :date, "Date (leave blank for today)" %>
            <%= form.date_field :date %>
        </div>
        <%= form.submit "Add Expense", class: 'btn-outline-primary' %>
    <% end %>
    <%= button_to "Cancel", expenses_path, method: :get, class: 'btn btn-outline-primary', params: { trip_id: @trip.id } %>
</div>
