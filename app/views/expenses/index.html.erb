<style>
body {
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    flex-flow: column;
    color: #fff;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
}

body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: url(<%= asset_path 'course_1.jpg' %>) center/cover no-repeat;
    z-index: -1;
}

.next-trip-cost {
    background-color: #fff;
    opacity: .8;
    padding: 30px 40px;
    margin: 20px auto;
    color: black;
    border-radius: 10px;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    text-align: left;
    max-width: 900px;
    width: 90%;
}

.next-trip-cost > h1 {
    font-size: 60px;
    text-align: center;
}

.next-trip-cost > h3 {
    font-size: 40px;
}

.expense-card {
    background-color: rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 10px;
    padding: 16px 24px;
    margin: 12px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
}

.expense-card-info h4 {
    margin: 0 0 4px 0;
    font-size: 1.1em;
    font-weight: bold;
}

.expense-card-info h5 {
    margin: 0;
    font-size: 0.85em;
    font-weight: normal;
    color: #555;
}

.expense-card-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.line {
    border-top: 5px solid black;
}

.btn-outline-primary {
    margin: 1rem 0;
    background-color: white;
    opacity: .8;
    padding: 20px;
    font-size: 1em;
    color: black !important;
    outline: 0 none !important;
    box-shadow: none !important;
    border-color: black !important;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    border-radius: 10px;
}

.btn-outline-primary:hover {
    background-color: gray !important;
}

.btn-outline-danger {
    margin: 0;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    font-size: 0.85em;
    padding: 10px 16px;
    color: black !important;
    outline: 0 none !important;
    box-shadow: none !important;
    border-color: black !important;
    background-color: rgb(222, 74, 72);
    border-radius: 6px;
    cursor: pointer;
}

.btn-outline-danger:hover {
    background-color: rgb(191, 146, 112) !important;
}

.btn-sm {
    margin: 0;
    background-color: white;
    opacity: .8;
    padding: 10px 16px;
    font-size: 0.85em;
    color: black !important;
    outline: 0 none !important;
    box-shadow: none !important;
    border-color: black !important;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    border-radius: 6px;
    cursor: pointer;
}

.btn-sm:hover {
    background-color: gray !important;
}

@media (max-width: 800px) {
    body { align-items: stretch; }
}
</style>

<div class="next-trip-cost">
    <% flash.each do |name, msg| %>
        <div class="alert" role="alert">
            <%= content_tag :div, msg, class: name %>
        </div>
    <% end %>
    <h1>Expenses — KPC <%= @trip.number %></h1>
    <h3>Total: $<%= number_with_delimiter(@trip.total_expenses) %></h3>
    <hr class="line">
    <% if @expenses.any? %>
        <% @expenses.each do |expense| %>
            <div class="expense-card">
                <div class="expense-card-info">
                    <h4><%= expense.description %> &mdash; $<%= number_with_delimiter(expense.amount) %></h4>
                    <h5><%= expense.golfer&.nickname&.titleize %> &middot; <%= expense.date&.strftime('%A, %B %-d, %Y') %></h5>
                </div>
                <div class="expense-card-actions">
                    <%= button_to "Edit", edit_expense_path(expense), method: :get, class: 'btn-sm', params: { trip_id: @trip.id } %>
                    <%= button_to "Delete", expense_path(expense), method: :delete, class: 'btn-outline-danger', params: { trip_id: @trip.id }, data: { confirm: "Delete this expense?" } %>
                </div>
            </div>
        <% end %>
    <% else %>
        <h3 style="color: #888; font-style: italic;">No expenses recorded yet.</h3>
    <% end %>
    <hr class="line">
    <%= button_to "New Expense", new_expense_path, method: :get, class: 'btn btn-outline-primary', params: { trip_id: @trip.id } %>
    <%= button_to "Back to Finances", "/finances", method: :get, class: 'btn btn-outline-primary', params: { trip_id: @trip.id } %>
</div>
