<style>
body {
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    flex-flow: column;
    color: #fff;
    font-size: 40px;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
    'Lucida Sans', Arial, sans-serif;
}

body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: url(<%= asset_path 'course_5.jpg' %>) center/cover no-repeat;
    z-index: -1;
}

.next-trip-cost {
  background-color: #fff;
  opacity: .8;
  padding: 20px;
  margin: 20px;
  color: black;
  outline: 0 none !important;
  box-shadow: none !important;
  border-color: black !important;
  font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
    'Lucida Sans', Arial, sans-serif;
  border-radius: 10px;
  font-size: 40px;
}

.next-trip-cost > h1 {
  font-size: 80px;
}

.next-trip-cost > h3 {
  font-size: 50px;
}

.form-group {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin: 10px 0;
}

.form-group label {
  font-size: 0.5em;
  font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
    'Lucida Sans', Arial, sans-serif;
  margin-bottom: 5px;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 10px;
  font-size: 0.4em;
  font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
    'Lucida Sans', Arial, sans-serif;
  border: 1px solid black;
  border-radius: 5px;
}

.form-group textarea {
  height: 200px;
  resize: vertical;
}

.btn-outline-primary-finances {
  margin: 20px;
  background-color: white;
  opacity: .8;
  padding: 20px;
  font-size: 1em;
  color: black !important;
  outline: 0 none !important;
  box-shadow: none !important;
  border-color: black !important;
  font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
    'Lucida Sans', Arial, sans-serif;
  border-radius: 10px;
}

.btn-outline-primary-finances:hover {
  background-color: gray !important;
}

.btn-outline-primary-finances:focus, .btn-outline-primary-finances:active:focus {
  outline: 0 none !important;
  box-shadow: none !important;
  border: none !important;
}

.btn-outline-primary {
  margin: 20px;
  background-color: white;
  opacity: .8;
  padding: 20px;
  font-size: .5em;
  color: black !important;
  outline: 0 none !important;
  box-shadow: none !important;
  border-color: black !important;
  font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
    'Lucida Sans', Arial, sans-serif;
  border-radius: 10px;
}

.btn-outline-primary:hover {
  background-color: gray !important;
}

.btn-outline-primary:focus, .btn-outline-primary:active:focus {
  outline: 0 none !important;
  box-shadow: none !important;
  border: none !important;
}

.line {
  border-top: 5px solid black;
}

@media (max-width: 800px) {
  body {
    align-items: stretch;
  }
}
</style>

<div class="next-trip-cost">
  <% flash.each do |name, msg| %>
    <div class="alert" role="alert">
      <%= content_tag :div, msg, class: name %>
    </div>
  <% end %>
  <h1>Send Email</h1>
  <h3>Send a message to all golfers on a trip</h3>
  <hr class="line">

  <%= form_with url: "/announcements", method: :post, local: true do |form| %>
    <div class="form-group">
      <%= form.label :trip_id, "Trip" %>
      <%= form.select :trip_id, @trips.map { |t| ["KPC #{t.number}", t.id] }, {}, class: "" %>
    </div>

    <div class="form-group">
      <%= form.label :subject, "Subject" %>
      <%= form.text_field :subject, placeholder: "Email subject" %>
    </div>

    <div class="form-group">
      <%= form.label :body, "Message" %>
      <%= form.text_area :body, placeholder: "Write your message here..." %>
    </div>

    <%= form.submit "Send Email", class: "btn btn-outline-primary-finances" %>
  <% end %>

  <hr class="line">
  <form action="/dashboard">
    <button type="submit" class="btn btn-outline-primary">DASHBOARD</button>
  </form>
</div>
