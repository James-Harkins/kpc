<!DOCTYPE html>
<html>
<body style="margin:0; padding:0; background-color:#f0f0f0; font-family:'Trebuchet MS', Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0f0f0; padding:30px 0;">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; background-color:#ffffff; border-radius:8px; overflow:hidden;">

          <!-- Header -->
          <tr>
            <td style="background-color:#1a4d2e; padding:36px 40px; text-align:center;">
              <div style="font-size:42px; line-height:1; margin-bottom:12px;">🎉</div>
              <h1 style="color:#ffffff; margin:0 0 8px; font-size:26px; font-weight:bold; letter-spacing:1px;">
                You're All Paid Up!
              </h1>
              <p style="color:#a8d5b5; margin:0; font-size:15px;">
                KPC <%= @trip.number %> &bull; <%= @trip.location %> &bull; <%= @trip.year %>
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:32px 40px;">

              <p style="color:#333333; font-size:16px; margin:0 0 28px; line-height:1.5;">
                Hey <strong><%= @golfer.nickname %></strong>, your balance is paid in full. You're all squared up &mdash; see you in <strong><%= @trip.location %></strong>!
              </p>

              <!-- Paid in full confirmation -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a4d2e; border-radius:6px; margin-bottom:28px;">
                <tr>
                  <td style="padding:14px 16px; color:#ffffff; font-size:16px; font-weight:bold;">
                    Remaining Balance
                  </td>
                  <td style="padding:14px 16px; color:#ffffff; font-size:16px; font-weight:bold; text-align:right;">
                    $0
                  </td>
                </tr>
              </table>

              <p style="color:#333333; font-size:15px; margin:0; line-height:1.5;">
                Total paid: <strong>$<%= @golfer_trip.cost %></strong>. Nothing left to do but show up and have a good time!
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f5faf7; padding:20px 40px; text-align:center; border-top:1px solid #ddeee4;">
              <p style="color:#aaaaaa; font-size:12px; margin:0;">
                Kitchen Pass Classic &bull; See you on the course 🏌️
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
