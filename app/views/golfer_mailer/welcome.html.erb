<!DOCTYPE html>
<html>
<body style="margin:0; padding:0; background-color:#f0f0f0; font-family:'Trebuchet MS', Arial, sans-serif;">

  <!-- Outer wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0f0f0; padding:30px 0;">
    <tr>
      <td align="center">

        <!-- Card -->
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; background-color:#ffffff; border-radius:8px; overflow:hidden;">

          <!-- Header -->
          <tr>
            <td style="background-color:#1a4d2e; padding:36px 40px; text-align:center;">
              <div style="font-size:42px; line-height:1; margin-bottom:12px;">⛳</div>
              <h1 style="color:#ffffff; margin:0 0 8px; font-size:26px; font-weight:bold; letter-spacing:1px;">
                Welcome to KPC
              </h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:32px 40px;">

              <p style="color:#333333; font-size:16px; margin:0 0 20px; line-height:1.5;">
                Hey <strong><%= @golfer.nickname %></strong>,
              </p>

              <p style="color:#333333; font-size:16px; margin:0 0 20px; line-height:1.5;">
                Welcome to the Kitchen Pass Classic! Your account was just created by the site admin.
              </p>

              <p style="color:#333333; font-size:16px; margin:0 0 28px; line-height:1.5;">
                Click the button below to set your password and access your account:
              </p>

              <!-- Set Password Button -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:28px;">
                <tr>
                  <td align="center">
                    <a href="<%= @set_password_url %>" style="display:inline-block; background-color:#1a4d2e; color:#ffffff; font-size:15px; font-weight:bold; padding:14px 32px; border-radius:6px; text-decoration:none; letter-spacing:0.5px;">
                      Set Your Password
                    </a>
                  </td>
                </tr>
              </table>

              <p style="color:#777777; font-size:14px; margin:0 0 20px; line-height:1.5;">
                You can also use the "Forgot My Password" button on the login page if this link expires.
              </p>

              <p style="color:#777777; font-size:14px; margin:0 0 20px; line-height:1.5;">
                Please add your t-shirt size to your profile. This will be used for KPC giveaways.
              </p>

              <p style="color:#777777; font-size:14px; margin:0; line-height:1.5;">
                All future KPC communications will be sent directly from the website. You can expect to see emails from this address later this year when we open registration.
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f5faf7; padding:20px 40px; text-align:center; border-top:1px solid #ddeee4;">
              <p style="color:#aaaaaa; font-size:12px; margin:0;">
                Kitchen Pass Classic &bull; See you on the course 🏌️
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
