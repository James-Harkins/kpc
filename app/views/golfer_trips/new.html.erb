<style>
body {
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
      'Lucida Sans', Arial, sans-serif;
}

body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: url(<%= asset_path 'course_8.jpg' %>) center/cover no-repeat;
    z-index: -1;
}

.trip-register-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    text-align: left;
    margin: 20px auto;
    padding: 30px 40px;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
      'Lucida Sans', Arial, sans-serif;
    color: black;
    background-color: white;
    opacity: 0.8;
    border-radius: 10px;
    max-width: 900px;
    width: 90%;
    font-size: 22px;
}

.trip-register-container > h1 {
    font-size: 60px;
    text-align: center;
    width: 100%;
}

.info-box {
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    padding: 14px 20px;
    margin: 12px 0 20px;
    width: 100%;
    box-sizing: border-box;
}

.info-box ul {
    margin: 0;
    padding-left: 20px;
    font-size: 1em;
    line-height: 1.7;
}

.enchilada-section {
    width: 100%;
    margin-bottom: 20px;
}

.line {
    border-top: 5px solid black;
    margin: 20px 0;
}

.date-card {
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    padding: 16px 24px;
    margin: 12px 0;
    width: 100%;
    box-sizing: border-box;
}

.date-card h3 {
    margin: 0 0 10px 0;
    font-size: 1.1em;
    font-weight: bold;
}

.checkbox-item {
    display: flex;
    align-items: center;
    padding: 6px 0;
    font-size: 1em;
}

.checkbox-item input[type="checkbox"] {
    margin-right: 10px;
    width: 18px;
    height: 18px;
    cursor: pointer;
    flex-shrink: 0;
}

.btn-outline-primary {
    margin: 1rem 0;
    background-color: white;
    opacity: 0.8;
    padding: 20px;
    font-size: 1.2em;
    color: black !important;
    outline: 0 none !important;
    box-shadow: none !important;
    border-color: black !important;
    font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande',
        'Lucida Sans', Arial, sans-serif;
    border-radius: 10px;
    cursor: pointer;
}

.btn-outline-primary:hover {
    background-color: gray !important;
}

.btn-outline-primary:focus, .btn-outline-primary:active:focus {
    outline: 0 none !important;
    box-shadow: none !important;
    border: none !important;
}

.cost-summary {
    background-color: rgba(255, 255, 255, 0.95);
    border: 2px solid rgba(0, 0, 0, 0.15);
    border-radius: 10px;
    padding: 16px 24px;
    margin: 16px 0 8px;
    width: 100%;
    box-sizing: border-box;
    font-size: 1.1em;
    position: sticky;
    top: 20px;
    z-index: 10;
}

.cost-summary .discount-note {
    display: none;
    color: green;
    font-size: 0.85em;
    margin-top: 4px;
}

@media (max-width: 800px) {
    body {
        align-items: stretch;
    }
}
</style>

<div class='trip-register-container'>
    <h1>REGISTER FOR KPC <%= @next_trip.number %></h1>

    <% flash.each do |name, msg| %>
        <div class="alert" role="alert">
            <%= content_tag :div, msg, class: name %>
        </div>
    <% end %>

    <div class="info-box">
        <ul>
            <li>Check off each night and round that you will attend, then click the submit button.</li>
            <li>Your total cost is calculated in real time, which you can see in the "Your total" box.</li>
            <li>If you will attend the whole trip, just click "Give me the whole enchilada."</li>
            <li>If you attend the whole trip, Saturday night is free.</li>
            <li>Costs for "Night at House" include dinner that night and breakfast the following morning.</li>
            <li>Round prices include $15 for contests.</li>
            <li>Rounds listed as "à la carte" are not included in your KPC costs.</li>
            <li>You will pay for à la carte rounds at the course.</li>
            <li>If you will play the à la carte round, please check the box so we have a head count.</li>
        </ul>
    </div>

    <div class="enchilada-section">
        <%= button_to "Give me the whole enchilada, bud!", "/register_trip", params: {full_trip: true, trip_id: @next_trip.id}, class: 'btn-outline-primary' %>
    </div>

    <hr class="line">

    <%= form_with url: "/register_trip", method: :post, params: {trip_id: @next_trip.id}, local: true do |form| %>
        <div class="cost-summary">
            <strong>Your total: $<span id="running-total">0</span></strong>
            <div class="discount-note" id="discount-note">Full trip discount applied — Saturday night is free!</div>
        </div>

        <% @trip.each do |date| %>
            <div class="date-card">
                <h3><%= date[:date] %></h3>
                <div class="checkbox-item">
                    <%= check_box_tag 'nights[]', date[:night][:id], false, data: { cost: date[:night][:cost] }, onchange: 'updateTotal()' %>
                    <span>Night at House &mdash; $<%= date[:night][:cost] %></span>
                </div>
                <% if date[:round].values.any? %>
                    <div class="checkbox-item">
                        <%= check_box_tag 'rounds[]', date[:round][:id], false, data: { cost: date[:round][:cost] }, onchange: 'updateTotal()' %>
                        <% if date[:round][:cost] == 0 %>
                            <span>Round &mdash; à la carte</span>
                        <% else %>
                            <span>Round &mdash; $<%= date[:round][:cost] %></span>
                        <% end %>
                    </div>
                <% end %>
            </div>
        <% end %>

        <%= form.submit "Sign me up, motherfucker!", class: 'btn-outline-primary' %>
    <% end %>
</div>

<script>
var firstNightCost = <%= @next_trip.nights.order(:date).first&.cost || 0 %>;
var totalNights = document.querySelectorAll('input[name="nights[]"]').length;
var totalRounds = document.querySelectorAll('input[name="rounds[]"]').length;

function updateTotal() {
    var nightsChecked = document.querySelectorAll('input[name="nights[]"]:checked');
    var roundsChecked = document.querySelectorAll('input[name="rounds[]"]:checked');

    var total = 0;
    nightsChecked.forEach(function(cb) { total += parseInt(cb.dataset.cost) || 0; });
    roundsChecked.forEach(function(cb) { total += parseInt(cb.dataset.cost) || 0; });

    var isFullTrip = (nightsChecked.length === totalNights && roundsChecked.length === totalRounds);
    if (isFullTrip) total -= firstNightCost;

    document.getElementById('running-total').textContent = total;
    document.getElementById('discount-note').style.display = isFullTrip ? 'block' : 'none';
}
</script>
